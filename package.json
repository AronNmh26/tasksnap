{
  "name": "tasksnap",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "android:tunnel": "expo start --android --tunnel",
    "ios": "expo run:ios",
    "ios:tunnel": "expo start --ios --tunnel",
    "web": "expo start --web",
    "export:web": "expo export -p web && node tools/copy-legal-pages.js",
    "deploy:firebase": "npm run export:web && npx firebase-tools deploy --only hosting",
    "functions:install": "npm --prefix functions install",
    "functions:build": "npm --prefix functions run build",
    "functions:serve": "npm run functions:build && npx firebase-tools emulators:start --only functions",
    "functions:deploy": "npm run functions:build && npx firebase-tools deploy --only functions",
    "deploy:all": "npm run export:web && npx firebase-tools deploy --only hosting,functions",
    "test": "jest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/app-check": "^24.0.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/bottom-tabs": "^7.13.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.9.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.0",
    "expo-module-scripts": "^5.0.8",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "pdf-parse": "^2.4.5",
    "react-test-renderer": "^19.1.0",
    "tesseract.js": "^7.0.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "moduleNameMapper": {
      "^@expo/vector-icons$": "<rootDir>/test/mocks/expoVectorIcons.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(expo|@expo|react-native|@react-native|@react-navigation|expo-modules-core|@testing-library/react-native)/)"
    ]
  }
}
