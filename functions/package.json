{
  "name": "tasksnap-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf lib",
    "start": "node lib/server.js",
    "serve": "npm run build && npx firebase-tools emulators:start --only functions --config ../firebase.json",
    "deploy": "npx firebase-tools deploy --only functions --config ../firebase.json",
    "lint": "echo \"No lint configured\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^6.6.0",
    "nodemailer": "^6.10.1",
    "tasksnap": "file:.."
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^22.18.11",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2"
  }
}
